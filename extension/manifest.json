{
  "manifest_version": 3,
  "name": "YouTubeGist Ext",
  "version": "0.1.0",
  "description": "在观看 YouTube 视频时快速打开对应的 YouTubeGist 页面。",
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://m.youtube.com/*",
    "https://youtu.be/*",
    "https://www.bilibili.com/*",
    "https://m.bilibili.com/*",
    "https://b23.tv/*",
    "https://api.bilibili.com/*",
    "https://www.youtubegist.com/*"
  ],
  "action": {
    "default_title": "YouTubeGist",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://m.youtube.com/*", "https://youtu.be/*", "https://www.bilibili.com/*", "https://m.bilibili.com/*", "https://b23.tv/*"],
      "js": [
        "platform-adapter.js",
        "adapters/youtube-adapter.js",
        "adapters/bilibili-adapter.js",
        "platform-manager.js",
        "content.js"
      ],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
